$attribute @s attack_damage modifier add rr_aea:enchantment.enraging_vice.attack_damage $(dmg) add_multiplied_total
$attribute @s movement_speed modifier add rr_aea:enchantment.enraging_vice.movement_speed $(speed) add_multiplied_total
$attribute @s jump_strength modifier add rr_aea:enchantment.enraging_vice.jump_strength $(jump) add_multiplied_total
$attribute @s safe_fall_distance modifier add rr_aea:enchantment.enraging_vice.safe_fall $(jump) add_multiplied_total
