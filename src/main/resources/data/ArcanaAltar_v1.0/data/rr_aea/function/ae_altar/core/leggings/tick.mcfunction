# Page Change depending on interaction being clicked
execute as @e[type=interaction,limit=1,sort=nearest,tag=ArenAEALeggingsIArrowRight,tag=ArenAEALeggingsIP1,distance=..5] if data entity @s interaction.timestamp run execute as @n[type=marker,limit=1,sort=nearest,tag=ArenAEADTMain,distance=..5] at @s run playsound minecraft:item.book.page_turn player @a[distance=..15] ~ ~ ~ 1.2 1.125 0
