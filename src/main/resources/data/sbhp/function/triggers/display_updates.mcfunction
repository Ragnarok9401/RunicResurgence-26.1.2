tellraw @s[scores={rr.system.UpdateNumber=..1}] ["",{"text":"- SBHP Update: ","color":"gold"},{"text":"Version 0.4 - ","bold":true,"color":"light_purple"},{"text":"Scores, Boards, and Health Points","color":"light_purple"},"\n",{"text":"  • ","bold":true,"color":"gold"},{"text":"Major Changes","bold":true,"underlined":true,"color":"gold","hover_event":{"action":"show_text","value":[{"text":"  • New health system overhauls much of the vanilla health system, enabling far more direct and intricate control over every aspect of a player's health.\n","color":"blue"},{"text":"  • SBHP has some interactions with status effects. For instance, having Strength will decrease the time it takes to begin healing after being damaged, and Weakness has the opposite effect.\n","color":"gold"},{"text":"  • A small Damage Indicator now displays above a player's head when damaged. The indicator is accurate to the exact damage the player is dealt with SBHP.\n","color":"blue"},{"text":"  • By default, a player will now start with 50 HP, representative of roughly 1/4 of the vanilla amount. However, all players can eat unique foods to increase their Max Health by 450.\n","color":"gold"},{"text":"  • Several config options have been introduced which allow dynamic control over the system's functions. One important option is the Damage Modification option, which alters the total damage a player takes (by default, it's 115, representing +15%).\n","color":"blue"},{"text":"  • Because Armor values above 20 do not function properly in Vanilla, SBHP includes a formula for damage calculation at armor values above 20. Armor levels are calculated dynamically and can be pushed far past vanilla limits.\n","color":"gold"},{"text":"  • Food and Food Saturation now modify how much you heal per tick. Having a high amount of Food and Food Saturation will increase your overall healing, having high Food and low Saturation keeps it at normal levels, and having low Food and Saturation reduces natural healing.\n","color":"blue"},{"text":"  • Being in the Nether now reduces natural healing by a percentage.","color":"gold"}]}},"\n",{"text":"  • ","bold":true,"color":"gold"},{"text":"Minor Changes","bold":true,"underlined":true,"color":"blue","hover_event":{"action":"show_text","value":[{"text":"  • Several backend improvements, especially in regeneration calculations.\n","color":"gold"},{"text":"  • A Debug Health Modifier has been added for changing Max Health without directly modifying the SBHP scoreboards.","color":"blue"}]}}]
scoreboard players set @s[scores={rr.system.UpdateNumber=..1}] rr.system.UpdateNumber 2
